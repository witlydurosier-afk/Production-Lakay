rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper Functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isAdmin() {
      return isSignedIn() && isEmailVerified() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    // Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Admins Collection
    // Only existing admins can add new admins (or it's manually seeded)
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false; // Only manageable via Firebase Console for maximum security
    }

    // Products Collection
    match /products/{productId} {
      allow read: if true;
      allow create: if isAdmin() && isValidId(productId) && isValidProduct(incoming());
      allow update: if isAdmin() && isValidProduct(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['name', 'description', 'price', 'prices', 'imageUrl', 'category', 'unit', 'updatedAt'])
      );
      allow delete: if isAdmin();
    }

    function isValidProduct(data) {
      return data.keys().hasAll(['name', 'category', 'createdAt'])
        && data.name is string && data.name.size() > 0 && data.name.size() <= 200
        && data.category is string && data.category.size() > 0 && data.category.size() <= 100
        && data.createdAt is timestamp
        // Optional fields
        && (!('description' in data) || (data.description is string && data.description.size() <= 2000))
        && (!('price' in data) || (data.price is number && data.price >= 0))
        && (!('imageUrl' in data) || (data.imageUrl is string && data.imageUrl.size() <= 1000))
        && (!('unit' in data) || (data.unit is string && data.unit.size() <= 50))
        && (!('prices' in data) || (data.prices is list && data.prices.size() <= 10))
        && (data.keys().size() <= 10);
    }
  }
}
